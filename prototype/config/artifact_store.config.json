{
  "artifactStore": {
    "provider": "minio",
    "endpoint": "file:///Codex/ACDP/prototype/workspace/runtime_artifacts",
    "endpointEnv": "ACDP_ARTIFACT_ENDPOINT",
    "publicBaseUrl": "file:///Codex/ACDP/prototype/workspace/runtime_artifacts",
    "publicBaseUrlEnv": "ACDP_ARTIFACT_PUBLIC_BASE_URL",
    "bucket": "acdp-artifacts",
    "bucketEnv": "ACDP_ARTIFACT_BUCKET",
    "region": "",
    "regionEnv": "ACDP_ARTIFACT_REGION",
    "accessStyle": "path",
    "useSsl": false,
    "presignExpiresSeconds": 900,
    "rootUser": "acdp-bebe24",
    "rootUserEnv": "ACDP_ARTIFACT_ROOT_USER",
    "rootPassword": "vrQiIX8zIynZLxN9",
    "rootPasswordEnv": "ACDP_ARTIFACT_ROOT_PASSWORD",
    "accessKey": "acdp-bebe24",
    "accessKeyEnv": "ACDP_ARTIFACT_ACCESS_KEY",
    "secretKey": "vrQiIX8zIynZLxN9",
    "secretKeyEnv": "ACDP_ARTIFACT_SECRET_KEY",
    "serverDataDir": "/data/minio",
    "apiPort": 9000,
    "consolePort": 9001
  },
  "runtimeControl": {
    "adminBaseUrl": "http://122.51.13.230:8788",
    "adminBaseUrlEnv": "ACDP_RUNTIME_CONTROL_ADMIN_BASE_URL",
    "nodeId": "Runtime Node 001",
    "nodeIdEnv": "ACDP_RUNTIME_CONTROL_NODE_ID",
    "nodeName": "Runtime Node 001",
    "nodeNameEnv": "ACDP_RUNTIME_CONTROL_NODE_NAME",
    "nodeEnv": "local",
    "nodeEnvEnv": "ACDP_RUNTIME_CONTROL_NODE_ENV",
    "nodeAddress": "http://122.51.13.230:8791",
    "nodeAddressEnv": "ACDP_RUNTIME_CONTROL_NODE_ADDRESS",
    "registrationSecret": "runtime-node-local-secret",
    "registrationSecretEnv": "ACDP_RUNTIME_CONTROL_REGISTRATION_SECRET",
    "heartbeatIntervalSeconds": 30,
    "syncIntervalSeconds": 30,
    "nodeOfflineThresholdSeconds": 120,
    "downloadTimeoutMs": 600000,
    "statsFlushIntervalSeconds": 300,
    "statsFlushMaxBatchSize": 1000,
    "statsRetentionHours": 72
  },
  "runtimeDelivery": {
    "mode": "admin_http_signed",
    "adminArtifactBaseUrl": "http://122.51.13.230:8788",
    "adminArtifactBaseUrlEnv": "ACDP_RUNTIME_ARTIFACT_BASE_URL",
    "signedUrlSecret": "runtime-artifact-local-secret",
    "signedUrlSecretEnv": "ACDP_RUNTIME_ARTIFACT_SIGNED_URL_SECRET",
    "signedUrlExpiresSeconds": 300,
    "bindNodeId": true,
    "bindConfigVersion": true
  }
