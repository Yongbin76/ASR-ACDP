        "categoryCode": "gov_term",
        "priority": 92,
        "riskLevel": "medium",
        "replaceMode": "replace",
        "baseConfidence": 0.94,
        "pinyinRuntimeMode": "candidate",
        "customFullPinyinNoTone": "",
        "alternativeReadings": "",
        "sourceType": "import_csv",
        "remark": "示例"
      }
    ],
    "rules": [
