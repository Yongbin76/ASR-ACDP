      { "fieldName": "sourceType", "label": "来源类型", "required": false, "type": "string", "description": "来源标识", "example": "import_csv" },
      { "fieldName": "remark", "label": "备注", "required": false, "type": "string", "description": "附加说明", "example": "示例" }
    ],
    "examples": [
