{
  "sources": [
    {
      "sourceType": "cg3",
      "enabled": true,
      "description": "CG3 validation feed source",
      "transportType": "file_inbox",
      "endpointEnv": "ACDP_VALIDATION_FEED_CG3_ENDPOINT",
      "httpMethod": "GET",
      "timeoutMs": 10000,
      "authType": "bearer",
      "authHeaderName": "Authorization",
      "authTokenEnv": "ACDP_VALIDATION_FEED_CG3_TOKEN",
      "cursorQueryKey": "cursor",
      "cursorResponseField": "meta.nextCursor",
      "initialCursorEnv": "ACDP_VALIDATION_FEED_CG3_INITIAL_CURSOR",
      "includeCursorInAck": true,
      "ackType": "http_post",
      "ackEndpointEnv": "ACDP_VALIDATION_FEED_CG3_ACK_ENDPOINT",
      "ackMethod": "POST",
      "retryMaxAttempts": 3,
      "replayFromErrorDir": true
    },
    {
      "sourceType": "qa_feedback",
      "enabled": true,
      "description": "QA feedback validation feed source",
      "transportType": "file_inbox",
      "endpointEnv": "ACDP_VALIDATION_FEED_QA_ENDPOINT",
      "httpMethod": "GET",
      "timeoutMs": 10000,
      "authType": "bearer",
      "authHeaderName": "Authorization",
      "authTokenEnv": "ACDP_VALIDATION_FEED_QA_TOKEN",
      "cursorQueryKey": "cursor",
      "cursorResponseField": "meta.nextCursor",
      "initialCursorEnv": "ACDP_VALIDATION_FEED_QA_INITIAL_CURSOR",
      "includeCursorInAck": true,
      "ackType": "http_post",
      "ackEndpointEnv": "ACDP_VALIDATION_FEED_QA_ACK_ENDPOINT",
      "ackMethod": "POST",
      "retryMaxAttempts": 3,
      "replayFromErrorDir": true
    },
    {
      "sourceType": "online_feedback",
      "enabled": true,
      "description": "Online feedback validation feed source",
      "transportType": "file_inbox",
      "endpointEnv": "ACDP_VALIDATION_FEED_ONLINE_ENDPOINT",
      "httpMethod": "GET",
      "timeoutMs": 10000,
      "authType": "bearer",
      "authHeaderName": "Authorization",
      "authTokenEnv": "ACDP_VALIDATION_FEED_ONLINE_TOKEN",
      "cursorQueryKey": "cursor",
      "cursorResponseField": "meta.nextCursor",
      "initialCursorEnv": "ACDP_VALIDATION_FEED_ONLINE_INITIAL_CURSOR",
      "includeCursorInAck": true,
      "ackType": "http_post",
      "ackEndpointEnv": "ACDP_VALIDATION_FEED_ONLINE_ACK_ENDPOINT",
