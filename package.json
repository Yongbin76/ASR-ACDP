{
  "name": "ac-dict-platform-prototype",
  "version": "0.1.0",
  "private": true,
  "description": "Prototype for AC dictionary platform focused on Chinese ASR hotword correction.",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "check:env": "node ./prototype/src/cli/run-with-runtime-check.js --check-only",
    "prepare:data": "node ./prototype/src/cli/run-with-runtime-check.js ./prototype/src/cli/prepare-data.js",
    "bootstrap:db": "node ./prototype/src/cli/run-with-runtime-check.js ./prototype/src/cli/bootstrap-db.js",
    "setup:prototype": "node ./prototype/src/cli/run-with-runtime-check.js ./prototype/src/cli/setup-prototype.js",
    "build:snapshot": "node ./prototype/src/cli/run-with-runtime-check.js ./prototype/src/cli/build-snapshot.js",
    "prepare:release-bundle": "node ./prototype/src/cli/run-with-runtime-check.js ./prototype/src/cli/prepare-release-bundle.js",
    "prepare:visual-baseline": "node ./prototype/src/cli/run-with-runtime-check.js ./prototype/src/cli/prepare-visual-baseline.js",
    "import:validation-feeds": "node ./prototype/src/cli/run-with-runtime-check.js ./prototype/src/cli/import-validation-feeds.js",
    "demo:prototype": "node ./prototype/src/cli/run-with-runtime-check.js ./prototype/src/cli/demo-prototype.js",
    "smoke:admin": "node ./prototype/src/cli/run-with-runtime-check.js ./prototype/src/cli/admin-smoke.js",
    "smoke:console": "node ./prototype/src/cli/run-with-runtime-check.js ./prototype/src/cli/console-smoke.js",
    "smoke:runtime": "node ./prototype/src/cli/run-with-runtime-check.js ./prototype/src/cli/runtime-smoke.js",
    "verify:runtime-control": "node ./prototype/src/cli/run-with-runtime-check.js ./prototype/src/cli/verify-runtime-control.js",
    "verify:multi-runtime": "node ./prototype/src/cli/run-with-runtime-check.js ./prototype/src/cli/verify-multi-runtime.js",
    "check:control-config": "node ./prototype/src/cli/run-with-runtime-check.js ./prototype/src/cli/check-control-managed-config.js",
    "check:validation-feeds": "node ./prototype/src/cli/run-with-runtime-check.js ./prototype/src/cli/check-validation-feed-connectors.js",
    "check:api-contracts": "node ./prototype/src/cli/run-with-runtime-check.js ./prototype/src/cli/check-api-contract-snapshots.js",
    "check:visual-regression": "node ./prototype/src/cli/run-with-runtime-check.js ./prototype/src/cli/check-visual-regression.js",
    "check:v1-local-readiness": "node ./prototype/src/cli/run-with-runtime-check.js ./prototype/src/cli/check-v1-local-readiness.js",
    "check:k8s-target": "node ./prototype/src/cli/run-with-runtime-check.js ./prototype/src/cli/check-target-cluster.js",
    "local:minio:start": "node ./prototype/src/cli/run-with-runtime-check.js ./prototype/src/cli/local-minio.js start",
    "local:minio:stop": "node ./prototype/src/cli/run-with-runtime-check.js ./prototype/src/cli/local-minio.js stop",
    "local:minio:status": "node ./prototype/src/cli/run-with-runtime-check.js ./prototype/src/cli/local-minio.js status",
    "test:console": "node ./prototype/src/cli/run-with-runtime-check.js ./prototype/src/cli/console-e2e.js",
    "verify:host:console": "node ./prototype/src/cli/run-with-runtime-check.js ./prototype/src/cli/verify-host-console.js",
    "verify:validation-feeds": "node ./prototype/src/cli/run-with-runtime-check.js ./prototype/src/cli/verify-validation-feeds.js",
    "simulate": "node ./prototype/src/cli/run-with-runtime-check.js ./prototype/src/cli/simulate.js",
    "start:prototype": "node ./prototype/src/cli/run-with-runtime-check.js ./prototype/src/server.js",
    "start:runtime": "node ./prototype/src/cli/run-with-runtime-check.js ./prototype/src/runtime-server.js",
    "start:runtime:instance": "node ./prototype/src/cli/run-with-runtime-check.js ./prototype/src/cli/start-runtime-instance.js",
    "start:admin": "node ./prototype/src/cli/run-with-runtime-check.js ./prototype/src/admin-server.js",
    "service:start": "node ./prototype/src/cli/run-with-runtime-check.js ./prototype/src/cli/service-manager.js start",
    "service:start:runtime": "node ./prototype/src/cli/run-with-runtime-check.js ./prototype/src/cli/service-manager.js start runtime",
    "service:start:admin": "node ./prototype/src/cli/run-with-runtime-check.js ./prototype/src/cli/service-manager.js start admin",
    "service:stop": "node ./prototype/src/cli/run-with-runtime-check.js ./prototype/src/cli/service-manager.js stop",
    "service:stop:runtime": "node ./prototype/src/cli/run-with-runtime-check.js ./prototype/src/cli/service-manager.js stop runtime",
    "service:stop:admin": "node ./prototype/src/cli/run-with-runtime-check.js ./prototype/src/cli/service-manager.js stop admin",
    "service:status": "node ./prototype/src/cli/run-with-runtime-check.js ./prototype/src/cli/service-manager.js status",
    "service:status:runtime": "node ./prototype/src/cli/run-with-runtime-check.js ./prototype/src/cli/service-manager.js status runtime",
    "service:status:admin": "node ./prototype/src/cli/run-with-runtime-check.js ./prototype/src/cli/service-manager.js status admin",
    "test:unit": "node --test --test-concurrency=1 ./prototype/tests/unit/*.test.js",
    "test:unit:coverage": "node --test --experimental-test-coverage --test-concurrency=1 --test-coverage-lines=35 --test-coverage-functions=28 --test-coverage-branches=25 ./prototype/tests/unit/*.test.js",
    "test:concurrency": "node ./prototype/src/cli/run-with-runtime-check.js ./prototype/src/cli/concurrency-test.js",
    "test:prototype": "node ./prototype/src/cli/run-with-runtime-check.js ./prototype/tests/integration.js",
    "pm:migrate": "node ./project_management/scripts/migrate-legacy.js",
    "pm:render": "node ./project_management/scripts/render-docs.js",
    "pm:check": "node ./project_management/scripts/check-docs.js",
    "pm:brief": "node ./project_management/scripts/brief.js",
    "pm:sync": "node ./project_management/scripts/sync.js"
  },
  "dependencies": {
    "pinyin-pro": "^3.28.0"
  }
}
